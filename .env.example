APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=linn_games
DB_USERNAME=postgres
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@linn.games"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Claude API (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
# Path to claude CLI binary — use project-local install, NOT the user's global claude
# Default: node_modules/.bin/claude (installed via npm ci)
# CLAUDE_CLI_PATH=/var/www/node_modules/.bin/claude

# Optional tuning (defaults shown)
# CLAUDE_MAX_TOKENS=8192
# CLAUDE_RETRY_ATTEMPTS=3
# CLAUDE_RETRY_SLEEP_MS=500
# CLAUDE_INPUT_PRICE_CENTS=1
# CLAUDE_OUTPUT_PRICE_CENTS=4
# CLAUDE_LOW_BALANCE_THRESHOLD_PERCENT=10
# CLAUDE_DAILY_LIMIT_DASHBOARD=500
# CLAUDE_DAILY_LIMIT_SCOPING=500
# CLAUDE_DAILY_LIMIT_SEARCH=500
# CLAUDE_DAILY_LIMIT_REVIEW=500
# CLAUDE_DAILY_LIMIT_EVALUATION=500
# CLAUDE_DAILY_LIMIT_SYNTHESIS=500
# CLAUDE_DAILY_LIMIT_MAYRING=1000

# MayringCoder-MCP Service
MAYRING_MCP_ENDPOINT=http://mayring-api:8090
STRIPE_MAYRING_PRICE_ID=price_xxx   # Stripe recurring price ID (€5/Monat) — im Stripe-Dashboard anlegen
MAYRING_MCP_AUTH_TOKEN=
# MAYRING_MCP_TIMEOUT=60

# Pi Agent (Ollama-Worker für queue-worker ohne Anthropic-Kosten)
PI_AGENT_URL=http://mayring-pi:8091
# CLAUDE_USE_OLLAMA_WORKERS=false  # true = mayring_agent routet via Pi statt Anthropic
MAYRING_OLLAMA_MODEL=qwen2.5:1.5b

# Langdock Agents (UUIDs aus Langdock-URL)
LANGDOCK_BASE_URL=https://api.langdock.com/agent/v1/chat/completions
LANGDOCK_PRICE_PER_1K_TOKENS_CENTS=2
LANGDOCK_API_KEY=
LANGDOCK_AGENT_ID=
SCOPING_MAPPING_AGENT=
SEARCH_AGENT=
REVIEW_AGENT=
RESEARCH_RETRIEVAL_AGENT=
EVALUATION_AGENT=
PICO_AGENT=
SYNTHESIS_AGENT=
MAYRING_AGENT=

# Master Agent für vereinfachte Research-Pipeline (Issue #136)
MASTER_RESEARCH_AGENT=

# Webhook-Signatur für Langdock Callbacks (POST /api/webhooks/langdock/agent-result)
LANGDOCK_WEBHOOK_SECRET=

# Daily Limits pro Agent (in Cents; 0 = unbegrenzt)
# Schutz vor Token-Explosionen durch fehlerhafte Agent-Loops (Issue #122)
LANGDOCK_DAILY_LIMIT_DASHBOARD=500
LANGDOCK_DAILY_LIMIT_SCOPING=500
LANGDOCK_DAILY_LIMIT_SEARCH=500
LANGDOCK_DAILY_LIMIT_REVIEW=500
LANGDOCK_DAILY_LIMIT_RETRIEVAL=500
LANGDOCK_DAILY_LIMIT_EVALUATION=500
LANGDOCK_DAILY_LIMIT_PICO=500
LANGDOCK_DAILY_LIMIT_SYNTHESIS=500
LANGDOCK_DAILY_LIMIT_MAYRING=500

# Ollama Service (läuft auf three.linn.games / 192.168.178.11, NICHT auf dem Production-Server)
OLLAMA_URL=http://192.168.178.11:11434

# PostgreSQL (for docker-compose)
POSTGRES_DATABASE=linn_games
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=change-me

# MCP PostgreSQL Endpoint Auth Token (Langdock AI access)
MCP_AUTH_TOKEN=
# SSE-Streaming nur für interne IPs erlauben (127.0.0.1, Docker-Netz, RFC-1918)
# true = extern gesperrt (empfohlen für Production), false = deaktiviert
MCP_RESTRICT_TO_INTERNAL=true

# MCP Agent DB User — restricted role with RLS enforced (no BYPASSRLS)
# Created automatically by migration 2026_04_03_100000_add_rls_agent_scope
LANGDOCK_DB_USERNAME=mcp_agent
LANGDOCK_DB_PASSWORD=

VITE_APP_NAME="${APP_NAME}"

# Stripe Pay-As-You-Go
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_MAYRING_PRICE_ID=price_xxx   # Stripe recurring price ID (€5/Monat) — im Stripe-Dashboard anlegen

