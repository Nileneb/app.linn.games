# Universal defaults — same across all deployments.
# Tenant-specific values come from GitHub Environment (secrets + variables).
# See: scripts/write-env.py

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_PORT=5432

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MEMCACHED_HOST=127.0.0.1

AWS_DEFAULT_REGION=eu-central-1
AWS_USE_PATH_STYLE_ENDPOINT=false

CLAUDE_USE_DIRECT_API=true
CLAUDE_USE_OLLAMA_WORKERS=false

MCP_RESTRICT_TO_INTERNAL=true

VITE_APP_NAME=
