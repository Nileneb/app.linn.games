APP_ENV=testing

# Test-spezifische Mail-Konfiguration
# Kein SMTP-Email-Versand in Tests - nutze Array-Mailer
MAIL_MAILER=array

# Broadcasting ist in Tests nicht nötig
BROADCAST_CONNECTION=null

# Session und Queue für Tests
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# Separater MCP-Agent-User (nicht der Hauptbenutzer linn_games)
# Verhindert, dass disable_langdock_agent_db_user-Migration den Hauptbenutzer sperrt
LANGDOCK_DB_USERNAME=mcp_agent
