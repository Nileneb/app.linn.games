# docker/common/nginx/dockerfile

# Stage 1: PHP + Composer (build vendor)
FROM php:8.4-cli AS php_vendor
WORKDIR /var/www
COPY . /var/www
RUN rm -rf /var/www/tests /var/www/.git /var/www/.github \
    /var/www/.gitignore /var/www/.dockerignore /var/www/node_modules /var/www/.env* \
    || true
RUN mkdir -p storage/framework/cache storage/framework/sessions storage/framework/views storage/logs bootstrap/cache
RUN apt-get update && apt-get install -y --no-install-recommends \
    unzip git curl libicu-dev libzip-dev && \
    docker-php-ext-install intl zip && \
    curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin \
    --filename=composer && \
    composer install --no-dev --optimize-autoloader && \
    apt-get autoremove -y && apt-get clean && rm -rf /var/lib/apt/lists/*

# Stage 2: Node.js (npm build)
FROM node:24-alpine AS node_build
WORKDIR /var/www

# Copy only relevant files for the build
COPY package.json vite.config.js /var/www/
COPY resources/ /var/www/resources/
COPY public/ /var/www/public/
COPY composer.json composer.lock /var/www/
COPY artisan /var/www/
COPY bootstrap/ /var/www/bootstrap/
COPY config/ /var/www/config/
COPY routes/ /var/www/routes/
COPY app/ /var/www/app/

# Copy vendor from PHP stage
COPY --from=php_vendor /var/www/vendor /var/www/vendor

# Node dependencies & build
RUN npm install || { echo "npm install failed"; exit 1; }
RUN npm run build || { echo "npm run build failed"; exit 1; }

# Stage 3: Nginx production image
FROM nginx:alpine

# Custom Nginx config
COPY ./docker/common/nginx/nginx.conf /etc/nginx/nginx.conf

# site config (token placeholder replaced at startup by entrypoint)
COPY ./docker/common/nginx/default.conf /etc/nginx/conf.d/default.conf

# Entrypoint script to inject secrets at runtime
COPY ./docker/common/nginx/docker-entrypoint.sh /docker-entrypoint.d/30-inject-secrets.sh
RUN chmod +x /docker-entrypoint.d/30-inject-secrets.sh

# Copy built assets
COPY --from=node_build /var/www/public /var/www/public

WORKDIR /var/www/public
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
