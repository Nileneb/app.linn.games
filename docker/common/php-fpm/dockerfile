# Stage 1: Build environment and Composer + npm dependencies
FROM php:8.4-fpm AS builder

# Install system dependencies and PHP extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    unzip \
    libpq-dev \
    libonig-dev \
    libssl-dev \
    libxml2-dev \
    libcurl4-openssl-dev \
    libicu-dev \
    libzip-dev \
    nodejs \
    npm \
    && docker-php-ext-install -j$(nproc) \
        pdo_mysql \
        pdo_pgsql \
        pgsql \
        opcache \
        intl \
        zip \
        bcmath \
        soap \
        pcntl \
    && pecl install redis \
    && docker-php-ext-enable redis \
    && apt-get autoremove -y && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

WORKDIR /var/www

# Copy the entire Laravel application code into the container
COPY . /var/www

# Ensure storage directories exist (excluded by .dockerignore)
RUN mkdir -p storage/framework/cache storage/framework/sessions storage/framework/views storage/logs bootstrap/cache \
    && chmod -R 775 storage bootstrap/cache

# Install Composer and dependencies
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer \
    && composer install --no-dev --optimize-autoloader --no-interaction --no-progress --prefer-dist

# Build frontend assets (Vite production build)
RUN npm ci && npm run build

# Stage 2: Production environment
FROM php:8.4-fpm AS production

# Install runtime libraries required for PHP extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libpq-dev \
    libicu-dev \
    libzip-dev \
    && apt-get autoremove -y && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Copy PHP extensions and libraries from the builder stage
COPY --from=builder /usr/local/lib/php/extensions/ /usr/local/lib/php/extensions/
COPY --from=builder /usr/local/etc/php/conf.d/ /usr/local/etc/php/conf.d/
COPY --from=builder /usr/local/bin/docker-php-ext-* /usr/local/bin/

# Copy Composer from builder stage for php-cli access
COPY --from=builder /usr/local/bin/composer /usr/local/bin/composer

# Use the default production PHP configuration
RUN mv "$PHP_INI_DIR/php.ini-production" "$PHP_INI_DIR/php.ini"

# Copy the application code and dependencies from the build stage
COPY --from=builder /var/www /var/www

# Copy built frontend assets
COPY --from=builder /var/www/public/build /var/www/public/build

WORKDIR /var/www

# Ensure correct permissions
RUN chown -R www-data:www-data /var/www

# Copy and make executable the entrypoint script
COPY ./docker/common/php-fpm/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Entrypoint runs as root for volume setup; php-fpm drops to www-data via pool config
ENTRYPOINT ["/entrypoint.sh"]
CMD ["php-fpm"]

# Stage 3: Testing environment (includes dev dependencies)
FROM production AS testing

USER root

# Raise memory limit for test runs (Pest + sorting needs >128MB)
RUN echo 'memory_limit = 512M' > /usr/local/etc/php/conf.d/99-test-memory.ini

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Copy full source including tests and dev config
COPY --chown=www-data:www-data . /var/www
RUN mkdir -p storage/framework/cache storage/framework/sessions storage/framework/views storage/logs bootstrap/cache \
    && chmod -R 775 storage bootstrap/cache

# Install ALL dependencies (including dev/test)
RUN composer install --optimize-autoloader --no-interaction --no-progress --prefer-dist

USER www-data
